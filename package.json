{
  "name": "nestjs-platform-elysia",
  "version": "0.1.0",
  "description": "NestJS HTTP adapter for the Elysia web framework on Bun",
  "license": "MIT",
  "author": "Pedro Henrique",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/REPLACE_WITH_OWNER/nestjs-platform-elysia.git"
  },
  "bugs": {
    "url": "https://github.com/REPLACE_WITH_OWNER/nestjs-platform-elysia/issues"
  },
  "homepage": "https://github.com/REPLACE_WITH_OWNER/nestjs-platform-elysia#readme",
  "publishConfig": {
    "access": "public"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "module": "src/index.ts",
  "type": "commonjs",
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "engines": {
    "bun": ">=1.1.0"
  },
  "keywords": [
    "nestjs",
    "elysia",
    "bun",
    "adapter",
    "http",
    "platform"
  ],
  "scripts": {
    "clean": "rm -rf dist",
    "build": "bun run clean && tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "lint": "biome check",
    "lint:fix": "biome check --write",
    "format": "biome format --write",
    "test": "bun test",
    "test:unit": "bun test test/unit",
    "test:e2e": "bun test test/e2e",
    "check": "bun run lint && bun run typecheck && bun run test",
    "prepublishOnly": "bun run check && bun run build",
    "example:basic": "cd examples/basic && bun run src/main.ts"
  },
  "dependencies": {
    "path-to-regexp": "^8.2.0",
    "tslib": "^2.7.0"
  },
  "peerDependencies": {
    "typescript": "^5",
    "@nestjs/common": "^10.0.0 || ^11.0.0",
    "@nestjs/core": "^10.0.0 || ^11.0.0",
    "elysia": "^1.0.0",
    "@elysiajs/cors": "^1.0.0",
    "@nestjs/websockets": "^10.0.0 || ^11.0.0",
    "@nestjs/platform-ws": "^10.0.0 || ^11.0.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.0.0"
  },
  "peerDependenciesMeta": {
    "@elysiajs/cors": {
      "optional": true
    },
    "@nestjs/websockets": {
      "optional": true
    },
    "@nestjs/platform-ws": {
      "optional": true
    }
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.14",
    "@elysiajs/cors": "^1.0.0",
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-ws": "^11.1.19",
    "@nestjs/testing": "^11.1.19",
    "@nestjs/websockets": "^11.1.19",
    "@types/bun": "latest",
    "@types/ws": "^8.18.1",
    "elysia": "^1.0.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.0",
    "typescript": "^5",
    "ws": "^8.20.0"
  }
}
